def menu_uu():
    menu_options = {
        1: show_useful_tables,
        2: clear_tables,
        3: main,
        4: export_csv,
        5: compliant_rating,

        6: exit
    }

    while True:
        print("\n----NETWORK COMPLIANCE-ING-----")
        print("1-Show current tables")
        print("2-Clear current tables.")
        print("3-INPUT CONFIGS.")
        print("4-Export Tables as CSV.")
        print("5-View compliance Issues.")
        #print("6-Run ML Risk Analysis")
        #print("7-SQL Table Manipulation.")
        #print("8-Import fake data for ML")
        print("6-Exit")
        print("===================================")

        try:
            user_input = int(input("Choose number [1-6]: "))
            chosen = menu_options.get(user_input)

            if chosen:
                chosen()
            else:
                print("Invalid option")

        except ValueError:
            print("\n>>>> TRY AGAIN, ENTER A NUMBER 1-7 <<<<")


menu_uu()
